GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Public web-client runtime overrides. Keep API base relative in normal deployments
# so HttpOnly cookie sessions remain same-origin.
RESEARCH_DIGEST_CONFIG_PATH=config.yaml
RESEARCH_DIGEST_API_BASE_URL=/api
RESEARCH_DIGEST_REQUEST_TIMEOUT_MS=20000
RESEARCH_DIGEST_ENV=production

# Newsletter email delivery
# SMTP (funziona in locale / VPS; su Render le porte SMTP sono bloccate)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your-address@gmail.com
SMTP_USERNAME=your-address@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_USE_TLS=true

# SendGrid API (alternativa HTTP per cloud: Render, Heroku, ecc.)
# Imposta SENDGRID_API_KEY e l'app userà l'API REST al posto di SMTP.
# Ottieni una chiave gratuita su https://sendgrid.com (100 email/giorno).
# SENDGRID_API_KEY=SG.xxxxx

# Telegram delivery
TELEGRAM_BOT_TOKEN=123456789:telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
# Keep this true only in one process. Use the dedicated worker in multi-process deployments.
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_POLL_INTERVAL_SECONDS=15
TELEGRAM_LOG_LEVEL=INFO
TELEGRAM_AUTO_GENERATE_DIGEST=true
TELEGRAM_DIGEST_CONFIG_PATH=config.yaml
TELEGRAM_SEND_MAX_RETRIES=3
TELEGRAM_BROADCAST_DELAY_SECONDS=0.04

# Firebase Cloud Messaging local configuration
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=data/firebase/service-account.json
FIREBASE_TOKEN_STORE_PATH=data/firebase/fcm_tokens.json
FIREBASE_DEFAULT_TOPIC=research-digest
FIREBASE_WEB_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef123456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
FIREBASE_VAPID_KEY=your-web-push-vapid-public-key

# Firestore remote persistence (Render.com / production)
# Set FIREBASE_ENABLED=true and provide the service-account JSON inline:
# FIREBASE_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", ...}
# FIREBASE_PROJECT_ID is shared with FCM above.
# When Firestore is on, auth, subscribers, saved-news and Telegram data live
# in Firestore instead of local JSON files.
